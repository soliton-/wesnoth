#. [message]: speaker=Khavur
#. after Delfador kills several goblins, the goblin leader calls the retreat. Remaining goblins fall back to their keep
#: data/campaigns/The_Deceivers_Gambit/scenarios/02_Fort_Garard.cfg:108
#, fuzzy
msgid "Too many humans!"
msgstr "Il y a trop d’humains !"

#. [side]
#: data/campaigns/The_Deceivers_Gambit/scenarios/02_Fort_Garard.cfg:165
#: data/campaigns/The_Deceivers_Gambit/scenarios/02_Fort_Garard.cfg:177
#: data/campaigns/The_Deceivers_Gambit/scenarios/05_The_Deceiver.cfg:125
#: data/campaigns/The_Deceivers_Gambit/scenarios/05_The_Deceiver.cfg:140
